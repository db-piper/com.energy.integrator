      "uiComponent": "sensor",
      "decimals": 3,
      "title": {
        "en": "Interval Time"
      },
      "units": {
        "en": "s"
      }
    },
    "measure_time": {
      "type": "number",
      "getable": true,
      "setable": false,
      "icon": "/assets/time.svg",
      "insights": false,
      "uiComponent": null,
      "decimals": 0,
      "title": {
        "en": "Time"
      },
      "units": {
        "en": "ms"
      }
    },
    "string_interval": {
      "type": "string",
      "title": {
        "en": "Event Interval"
      },
      "getable": true,
      "setable": false,
      "icon": "/assets/interval.svg",
