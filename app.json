          "title": {
            "en": "Power"
          },
          "units": {
            "en": "W"
          },
          "decimals": 0,
          "getable": true
        },
        "meter_power": {
          "title": {
            "en": "Energy"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 3,
          "getable": true
        },
        "meter_power.today": {
          "title": {
            "en": "Energy Today"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 3,
          "getable": true
        },
        "measure_time": {
          "title": {
            "en": "Epoch Time"
          },
          "units": {
            "en": "ms"
          },
          "decimals": 0,
          "getable": true,
          "insights": true
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [],
      "images": {
        "small": "/drivers/power-integrator/assets/images/small.png",
        "large": "/drivers/power-integrator/assets/images/large.png",
        "xlarge": "/drivers/power-integrator/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "id": "reflected_device_id",
          "type": "text",
          "label": {
            "en": "Source Device ID"
          },
          "hint": {
            "en": "Paste the Homey UUID of the physical device you want to mirror."
          },
          "value": ""
        },
        {
          "id": "reflected_capability_id",
          "type": "text",
          "label": {
            "en": "Source Capability ID"
          },
          "hint": {
            "en": "The exact capability key name (e.g., measure_power)."
          },
          "value": "measure_power"
        }
      ],
      "repair": [
        {
          "id": "reflection_picker"
        }
      ],
      "id": "power-integrator"
    }
  ],
  "capabilities": {
    "measure_interval": {
      "type": "number",
      "getable": true,
      "setable": false,
      "icon": "/assets/time.svg",
