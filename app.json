{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.energy.integrator",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "brandColor": "#00A896",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Energy Integrator"
  },
  "description": {
    "en": "Integrates different electrical devices into a single energy hub"
  },
  "category": [
    "energy"
  ],
  "permissions": [
    "homey:manager:api"
  ],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "David Piper",
    "email": "david.piper@normandygite.org.uk"
  },
  "drivers": [
    {
      "name": {
        "en": "Power Integrator"
      },
      "class": "sensor",
      "capabilities": [
        "measure_power",
        "meter_power",
        "meter_power.today",
        "measure_time",
        "measure_interval"
